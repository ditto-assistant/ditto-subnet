# Pylon service config for one SN118 validator. Copy to pylon.env, fill in, keep
# out of git. Reference: VALIDATOR.md ("Set up Pylon") and
# https://github.com/bittensor-church/bittensor-pylon (docs/SERVICE.md).
# Secrets (tokens) must come from a secret manager in production, never committed.

# Chain the validator hotkey is registered on.
PYLON_BITTENSOR_NETWORK=finney

# Read token for open-access endpoints (metagraph / block reads). Any random string.
PYLON_OPEN_ACCESS_TOKEN=<random-read-token>

# One identity = the validator wallet + subnet, with a write token used for
# put_weights. The worker authenticates to this identity (PYLON_IDENTITY_NAME /
# PYLON_IDENTITY_TOKEN must match the name below and this token).
PYLON_IDENTITIES=["ditto"]
PYLON_ID_DITTO_WALLET_NAME=<coldkey-name>
PYLON_ID_DITTO_HOTKEY_NAME=<hotkey-name>
PYLON_ID_DITTO_NETUID=118
PYLON_ID_DITTO_TOKEN=<random-write-token>

# Persist in-flight weight submissions to the mounted volume so a restart resumes
# them (matches the pylon-data volume in docker-compose.yaml).
PYLON_DATABASE_PATH=/data/pylon.db

# Optional: token for the /metrics endpoint (empty = /metrics returns 403).
# PYLON_METRICS_TOKEN=<random-token>
