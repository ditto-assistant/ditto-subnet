# One independent SN118 validator. Copy to validator.env, fill in, keep out of
# git. Full reference: docs/VALIDATOR-ONBOARDING.md. Secrets (mnemonic, keys,
# tokens) must come from a secret manager in production, never committed.

# --- Required ---
VALIDATOR_PLATFORM_API_URL=https://<platform-host>
VALIDATOR_DITTOBENCH_API_URL=https://<dittobench-host>
VALIDATOR_HOTKEY=<your-validator-ss58>
NETUID=118
VALIDATOR_OPENROUTER_KEY=<secret>

# Signing source: prefer wallet files; the mnemonic is the container-friendly
# alternative. The coldkey is never needed on the box.
VALIDATOR_WALLET_NAME=<coldkey-name>
VALIDATOR_WALLET_HOTKEY=<hotkey-name>
# VALIDATOR_MNEMONIC=<12/24-word phrase>

# --- Chain / weight path: pick ONE ---
# Production (Pylon identity write):
PYLON_URL=http://<pylon-host>
PYLON_IDENTITY_NAME=<name>
PYLON_IDENTITY_TOKEN=<secret>
# Fallback / localnet (SDK set_weights): comment out the Pylon block above and use
# VALIDATOR_USE_SDK_WEIGHTS=1
# SUBTENSOR_NETWORK=local          # finney | test | local | ws://host:port

# --- Consensus-critical: identical network-wide, do NOT tune unilaterally ---
VALIDATOR_KOTH_MARGIN=0.01
VALIDATOR_KOTH_TAIL_SIZE=4
VALIDATOR_KOTH_CHAMPION_SHARE=0.9
# Statistical dethrone band: a challenger must clear max(margin, z*sqrt(se_c^2 +
# se_champ^2)) so a lead inside measurement noise cannot flip the crown. 0 = flat
# margin only.
VALIDATOR_KOTH_DETHRONE_Z=1.64
# P4 multi-seed confirmation: a version-bump re-score runs each champion/tail
# agent on this many common CRN seeds and dethrones on the median over them, so a
# crown flip must replicate across seeds. 1 = single-seed (pre-P4).
VALIDATOR_KOTH_CONFIRMATION_SEEDS=3

# --- Common knobs (defaults shown) ---
VALIDATOR_RUN_SIZE=full
VALIDATOR_SWEEP_SECONDS=120
VALIDATOR_EPOCH_SECONDS=3600
# VALIDATOR_REQUIRE_COMMIT_REVEAL=1   # set on finney; off on dev localnet
# WANDB_MODE=online                    # + WANDB_PROJECT / WANDB_ENTITY to publish telemetry
