# One independent SN118 validator. Copy to validator.env, fill in, keep out of
# git. Full reference: docs/VALIDATOR.md. Secrets (mnemonic, keys, tokens) must come
# from a secret manager in production, never committed.

# --- Required ---
VALIDATOR_PLATFORM_API_URL=https://platform-api.heyditto.ai/
VALIDATOR_DITTOBENCH_API_URL=https://<dittobench-host>
VALIDATOR_HOTKEY=<your-validator-ss58>
NETUID=118

# Signing source: prefer wallet files; the mnemonic is the container-friendly
# alternative. The coldkey is never needed on the box.
VALIDATOR_WALLET_NAME=<coldkey-name>
VALIDATOR_WALLET_HOTKEY=<hotkey-name>
# VALIDATOR_MNEMONIC=<12/24-word phrase>

# --- Weight path (Pylon) --- set up the service with scripts/pylon/; see VALIDATOR.md
PYLON_URL=http://<pylon-host>:8000
PYLON_IDENTITY_NAME=ditto
PYLON_IDENTITY_TOKEN=<write-token>

# --- Consensus-critical (identical network-wide, do NOT tune unilaterally) ---
# The KOTH margin / tail / champion-share / dethrone-z are frozen in code
# (ditto/validator/config.py), not env. Only the confirmation-seed count is set
# here: a version-bump re-score runs each champion/tail agent on this many common
# CRN seeds and dethrones on the median. 1 = single-seed (pre-P4).
VALIDATOR_KOTH_CONFIRMATION_SEEDS=3

# --- Common knobs (defaults shown) ---
VALIDATOR_RUN_SIZE=full
VALIDATOR_SWEEP_SECONDS=120
VALIDATOR_EPOCH_SECONDS=3600
# VALIDATOR_REQUIRE_COMMIT_REVEAL=1   # set on finney
# WANDB_MODE=online                    # + WANDB_PROJECT / WANDB_ENTITY to publish telemetry
