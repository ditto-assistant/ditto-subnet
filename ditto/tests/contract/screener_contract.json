{
  "ScreenResultRequest": {
    "properties": {
      "detail": {
        "default": "",
        "maxLength": 4000,
        "type": "string"
      },
      "passed": {
        "type": "boolean"
      },
      "screener_hotkey": {
        "pattern": "^[1-9A-HJ-NP-Za-km-z]{47,48}$",
        "type": "string"
      },
      "signature": {
        "pattern": "^[0-9a-fA-F]{128}$",
        "type": "string"
      }
    },
    "required": [
      "screener_hotkey",
      "signature",
      "passed"
    ],
    "type": "object"
  },
  "ScreenResultResponse": {
    "$defs": {
      "AgentStatus": {
        "enum": [
          "uploaded",
          "screening",
          "screening_passed",
          "screening_failed",
          "evaluating",
          "scored",
          "live",
          "ath_pending_review",
          "banned"
        ],
        "type": "string"
      }
    },
    "properties": {
      "accepted": {
        "type": "boolean"
      },
      "agent_id": {
        "format": "uuid",
        "type": "string"
      },
      "status": {
        "$ref": "#/$defs/AgentStatus"
      }
    },
    "required": [
      "agent_id",
      "status",
      "accepted"
    ],
    "type": "object"
  },
  "ScreenerQueueItem": {
    "$defs": {
      "AgentStatus": {
        "enum": [
          "uploaded",
          "screening",
          "screening_passed",
          "screening_failed",
          "evaluating",
          "scored",
          "live",
          "ath_pending_review",
          "banned"
        ],
        "type": "string"
      }
    },
    "properties": {
      "agent_id": {
        "format": "uuid",
        "type": "string"
      },
      "created_at": {
        "format": "date-time",
        "type": "string"
      },
      "miner_hotkey": {
        "type": "string"
      },
      "name": {
        "type": "string"
      },
      "sha256": {
        "type": "string"
      },
      "status": {
        "$ref": "#/$defs/AgentStatus"
      }
    },
    "required": [
      "agent_id",
      "miner_hotkey",
      "name",
      "sha256",
      "status",
      "created_at"
    ],
    "type": "object"
  },
  "ScreenerQueueResponse": {
    "$defs": {
      "AgentStatus": {
        "enum": [
          "uploaded",
          "screening",
          "screening_passed",
          "screening_failed",
          "evaluating",
          "scored",
          "live",
          "ath_pending_review",
          "banned"
        ],
        "type": "string"
      },
      "ScreenerQueueItem": {
        "properties": {
          "agent_id": {
            "format": "uuid",
            "type": "string"
          },
          "created_at": {
            "format": "date-time",
            "type": "string"
          },
          "miner_hotkey": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          },
          "status": {
            "$ref": "#/$defs/AgentStatus"
          }
        },
        "required": [
          "agent_id",
          "miner_hotkey",
          "name",
          "sha256",
          "status",
          "created_at"
        ],
        "type": "object"
      }
    },
    "properties": {
      "count": {
        "minimum": 0,
        "type": "integer"
      },
      "items": {
        "items": {
          "$ref": "#/$defs/ScreenerQueueItem"
        },
        "type": "array"
      }
    },
    "required": [
      "items",
      "count"
    ],
    "type": "object"
  }
}
