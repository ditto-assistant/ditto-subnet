{
  "ScreenerHeartbeatRequest": {
    "$defs": {
      "DockerHealth": {
        "additionalProperties": false,
        "properties": {
          "running_containers": {
            "maximum": 1000,
            "minimum": 0,
            "type": "integer"
          },
          "status": {
            "enum": [
              "healthy",
              "degraded",
              "unavailable"
            ],
            "type": "string"
          },
          "unhealthy_containers": {
            "maximum": 1000,
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "status",
          "running_containers",
          "unhealthy_containers"
        ],
        "type": "object"
      },
      "SystemMetrics": {
        "additionalProperties": false,
        "properties": {
          "collected_at": {
            "minimum": 0,
            "type": "integer"
          },
          "cpu_percent": {
            "maximum": 100,
            "minimum": 0,
            "multipleOf": 5,
            "type": "integer"
          },
          "disk_percent": {
            "maximum": 100,
            "minimum": 0,
            "multipleOf": 5,
            "type": "integer"
          },
          "docker": {
            "$ref": "#/$defs/DockerHealth"
          },
          "memory_percent": {
            "maximum": 100,
            "minimum": 0,
            "multipleOf": 5,
            "type": "integer"
          }
        },
        "required": [
          "collected_at",
          "cpu_percent",
          "memory_percent",
          "disk_percent",
          "docker"
        ],
        "type": "object"
      }
    },
    "additionalProperties": false,
    "properties": {
      "active_agent_id": {
        "anyOf": [
          {
            "format": "uuid",
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "policy_version": {
        "maximum": 2147483647,
        "minimum": 1,
        "type": "integer"
      },
      "protocol_version": {
        "maximum": 2147483647,
        "minimum": 1,
        "type": "integer"
      },
      "screener_hotkey": {
        "pattern": "^[1-9A-HJ-NP-Za-km-z]{47,48}$",
        "type": "string"
      },
      "signature": {
        "pattern": "^[0-9a-fA-F]{128}$",
        "type": "string"
      },
      "software_version": {
        "pattern": "^[0-9A-Za-z][0-9A-Za-z._+-]{0,63}$",
        "type": "string"
      },
      "state": {
        "enum": [
          "polling",
          "screening",
          "error",
          "paused"
        ],
        "type": "string"
      },
      "system_metrics": {
        "anyOf": [
          {
            "$ref": "#/$defs/SystemMetrics"
          },
          {
            "type": "null"
          }
        ],
        "default": null
      },
      "timestamp": {
        "minimum": 0,
        "type": "integer"
      }
    },
    "required": [
      "screener_hotkey",
      "software_version",
      "protocol_version",
      "policy_version",
      "state",
      "timestamp",
      "signature"
    ],
    "type": "object"
  },
  "ScreenerHeartbeatResponse": {
    "properties": {
      "accepted": {
        "type": "boolean"
      },
      "seen_at": {
        "format": "date-time",
        "type": "string"
      }
    },
    "required": [
      "accepted",
      "seen_at"
    ],
    "type": "object"
  }
}
