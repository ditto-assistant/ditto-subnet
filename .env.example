# Local dev environment template. Copy to `.env` and fill in real values:
#   cp .env.example .env
#
# `.env` is gitignored; this template is committed.


# --- API server ---

# Interface to bind. ``0.0.0.0`` inside containers; ``127.0.0.1`` to
# restrict to the loopback in local dev.
API_HOST=0.0.0.0

# TCP port the FastAPI app listens on. Host port 8001 is reserved for
# Pylon so 8000 is the default API slot.
API_PORT=8000

# Root logger level. One of DEBUG, INFO, WARNING, ERROR, CRITICAL.
API_LOG_LEVEL=INFO


# --- Pylon ---

# HTTP URL of the local Pylon container (see docker-compose.yml). Pylon
# is exposed on host port 8001 because the API server owns 8000.
PYLON_URL=http://localhost:8001

# Open-access token for read endpoints (neurons, blocks, extrinsics).
# Used by the API server and the smoke script. Any string Pylon was
# started with; not a secret in local dev.
PYLON_OPEN_ACCESS_TOKEN=dev-open-access

# Identity credentials. Required only for write endpoints (put_weights).
# Leave blank for read-only / smoke usage. The validator daemon needs both.
PYLON_IDENTITY_NAME=
PYLON_IDENTITY_TOKEN=


# --- Subnet ---

# Bittensor subnet netuid the codebase operates on.
NETUID=118

# Subtensor network the substrate-interface reader connects to for the
# Pylon events gap. One of: finney (mainnet), test (testnet), local, or
# a full wss:// URL.
SUBTENSOR_NETWORK=finney


# --- Postgres ---

# Connection details for the local docker-compose Postgres. Dev defaults
# match the service in docker-compose.yml.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ditto
POSTGRES_PASSWORD=ditto
POSTGRES_DB=ditto

# Pool sizing + per-command timeout. Tune in production for steady-state load.
POSTGRES_POOL_MIN_SIZE=2
POSTGRES_POOL_MAX_SIZE=10
POSTGRES_COMMAND_TIMEOUT=30.0
