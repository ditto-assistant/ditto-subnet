# Ditto Subnet environment reference
#
# Copy this file to .env and uncomment the settings needed by the process you
# are running. Never commit mnemonics, API keys, or access tokens.

# --- Miner CLI ---

# DITTO_NETWORK=finney
# DITTO_SUBTENSOR_CHAIN_ENDPOINT=ws://<subtensor-host>:9944
# WALLET_NAME=default
# HOTKEY_NAME=default

# --- Validator chain settings ---

# Compose hardcodes SN118. For local testing, explicitly replace both the
# platform URL and chain target; do not reuse the production .env.
SUBTENSOR_NETWORK=finney

# --- Validator worker ---

VALIDATOR_PLATFORM_API_URL=https://platform-api.heyditto.ai/
VALIDATOR_HOTKEY=<validator-ss58-address>

# Load the validator signing key from wallet files.
VALIDATOR_WALLET_NAME=<coldkey-name>
VALIDATOR_WALLET_HOTKEY=<hotkey-name>

# Weight path (Pylon). The root docker-compose.yml fixes the subnet to SN118 and
# derives Pylon's network, wallet, hotkey, and identity from the validator
# settings above, so you set only the token here. One PYLON_TOKEN guards both
# the open-access reads and the identity write. See docs/VALIDATOR.md, "First
# deployment".
PYLON_TOKEN=<random-token>       # generate with: openssl rand -base64 32

# --- Validator observability: shared W&B telemetry ---
# Aggregate scoring stats publish to the shared heyditto/ditto-sn118 project so
# miners and researchers can watch the subnet. WANDB_API_KEY is a single
# read+write key the Ditto team gives trusted validators confidentially; paste it
# below and NEVER commit it. Set WANDB_MODE=disabled to opt out.
WANDB_MODE=online
WANDB_PROJECT=ditto-sn118
WANDB_ENTITY=heyditto
WANDB_API_KEY=<shared key provided confidentially by the Ditto team>
# WANDB_RUN_NAME: leave unset. Each validator auto-names its run
# validator-<hotkey8>, so many validators sharing this one project never
# collide. Only set this to override that per-hotkey default.
# WANDB_RUN_NAME=<optional-run-name>
# VALIDATOR_LOG_LEVEL=INFO

# --- Validator automatic updates (optional, disabled by default) ---
# Legacy validator-only updater. Leave false after full-stack migration.
VALIDATOR_AUTO_UPDATE=false
# Set this only after the supervised full-stack `migrate` or `adopt` command.
# It replaces the whole digest-pinned production stack, waits for active work
# to drain, and never force-stops a benchmark. Never enable both generations.
# Read docs/FULL-STACK-UPDATES.md before installing its timer.
VALIDATOR_STACK_AUTO_UPDATE=false
# VALIDATOR_AUTO_UPDATE_DRAIN_TIMEOUT_SECONDS=4800
# VALIDATOR_AUTO_UPDATE_READY_TIMEOUT_SECONDS=180
# VALIDATOR_AUTO_UPDATE_CHECK_SECONDS=5

# --- DittoBench scorer and model gateway ---

# The Chutes key the model-relay uses to reach the locked Qwen3-32B upstream. It
# lives only in the relay, never in the scorer or the miner sandbox. Keep it in a
# secret manager.
RELAY_API_KEY=cpk-...

# Optional Pylon service setting.
# PYLON_METRICS_TOKEN=<random-token>
