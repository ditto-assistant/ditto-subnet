# Local dev environment template. Copy to `.env` and fill in real values:
#   cp .env.example .env
#
# `.env` is gitignored; this template is committed.


# --- API server ---

# Interface to bind. ``0.0.0.0`` inside containers; ``127.0.0.1`` to
# restrict to the loopback in local dev.
API_HOST=0.0.0.0

# TCP port the FastAPI app listens on. Host port 8001 is reserved for
# Pylon so 8000 is the default API slot.
API_PORT=8000

# Root logger level. One of DEBUG, INFO, WARNING, ERROR, CRITICAL.
API_LOG_LEVEL=INFO


# --- Pylon ---

# HTTP URL of the local Pylon container (see docker-compose.yml). Pylon
# is exposed on host port 8001 because the API server owns 8000.
PYLON_URL=http://localhost:8001

# Open-access token for read endpoints (neurons, blocks, extrinsics).
# Used by the API server and the smoke script. Any string Pylon was
# started with; not a secret in local dev.
PYLON_OPEN_ACCESS_TOKEN=dev-open-access

# Identity credentials. Required only for write endpoints (put_weights).
# Leave blank for read-only / smoke usage. The validator daemon needs both.
PYLON_IDENTITY_NAME=
PYLON_IDENTITY_TOKEN=


# --- Subnet ---

# Bittensor subnet netuid the codebase operates on.
NETUID=118

# Subtensor network the substrate-interface reader connects to for the
# Pylon events gap. One of: finney (mainnet), test (testnet), local, or
# a full wss:// URL.
SUBTENSOR_NETWORK=finney


# --- Postgres ---

# Connection details for the local docker-compose Postgres. Dev defaults
# match the service in docker-compose.yml.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ditto
POSTGRES_PASSWORD=ditto
POSTGRES_DB=ditto

# Pool sizing + per-command timeout. Tune in production for steady-state load.
POSTGRES_POOL_MIN_SIZE=2
POSTGRES_POOL_MAX_SIZE=10
POSTGRES_COMMAND_TIMEOUT=30.0


# --- Upload + pricing ---

# Ditto-controlled SS58 address that receives upload fees. Required at
# boot - the API server validates the value as a real SS58 string and
# refuses to start otherwise, so the literal below is intentionally
# broken to force operators to replace it before any real-money flow.
DITTO_UPLOAD_PAYMENT_ADDRESS=REPLACE_WITH_DITTO_SS58_ADDRESS

# Upload fee in USD. Converted to TAO via the CoinGecko oracle at quote
# time. Multiplied by DITTO_UPLOAD_FEE_BUFFER to absorb TAO price drift
# between the /upload/eval-pricing quote and the on-chain payment.
DITTO_UPLOAD_FEE_USD=5
DITTO_UPLOAD_FEE_BUFFER=1.4

# In-process pricing cache (seconds). CoinGecko has hourly granularity
# and rate limits, so we cache per process for an hour by default.
PRICING_CACHE_TTL_SECONDS=3600

# Hard cap on stale-while-revalidate. If CoinGecko has been unreachable
# for longer than this, /upload/eval-pricing returns 503 rather than
# quoting a stale price.
PRICING_MAX_STALE_SECONDS=86400

# Per-attempt CoinGecko HTTP timeout. Tenacity retries 3 attempts total.
PRICING_COINGECKO_TIMEOUT_SECONDS=5.0

# Operator kill switch. When set, the oracle returns this value verbatim
# and skips CoinGecko + cache entirely. Use during CoinGecko outages or
# if a market-data anomaly needs the fee held at a known value.
# TAO_PRICE_OVERRIDE_USD=


# --- Object storage (S3 / minio) ---

# S3 endpoint URL the API server reads/writes through. Defaults to the
# local minio service in docker-compose.yml. In prod, point at the
# real S3 / R2 / B2 endpoint.
STORAGE_ENDPOINT_URL=http://localhost:9000

# Bucket name where agent tarballs land. minio-create-bucket creates
# this on first ``docker compose up``.
STORAGE_BUCKET=ditto-agents

# Access credentials. minio defaults in dev compose; replace with real
# IAM credentials in prod.
STORAGE_ACCESS_KEY=minio
STORAGE_SECRET_KEY=miniominio

# Region the client should advertise. minio ignores; AWS S3 requires.
STORAGE_REGION=us-east-1

# Whether to speak TLS against the endpoint. False for local minio,
# true for prod against AWS S3 / R2.
STORAGE_USE_TLS=false

# Optional host overrides for the minio container in docker-compose.
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001
# MINIO_ROOT_USER=minio
# MINIO_ROOT_PASSWORD=miniominio
