# Ditto Subnet environment reference
#
# Copy this file to .env and uncomment the settings needed by the process you
# are running. Never commit mnemonics, API keys, or access tokens.

# --- Miner CLI ---

# DITTO_NETWORK=finney
# DITTO_SUBTENSOR_CHAIN_ENDPOINT=ws://<subtensor-host>:9944
# WALLET_NAME=default
# HOTKEY_NAME=default

# --- Shared worker settings ---

NETUID=118

# --- Validator worker ---

VALIDATOR_PLATFORM_API_URL=https://platform-api.heyditto.ai/
VALIDATOR_DITTOBENCH_API_URL=https://<dittobench-host>
VALIDATOR_HOTKEY=<validator-ss58-address>
# VALIDATOR_OPENROUTER_KEY=<secret>   # legacy: only when the model lock is off

# Load the validator signing key from wallet files.
VALIDATOR_WALLET_NAME=<coldkey-name>
VALIDATOR_WALLET_HOTKEY=<hotkey-name>

# A validator scores and sets weights by default. These switches support
# intentionally split deployments.
VALIDATOR_ENABLE_SCORING=true
VALIDATOR_ENABLE_WEIGHTS=true

# Weight path (Pylon identity mode). Set up the Pylon service with scripts/pylon/;
# see VALIDATOR.md, "Set up Pylon".
PYLON_URL=http://<pylon-host>:8000
PYLON_IDENTITY_NAME=ditto
PYLON_IDENTITY_TOKEN=<write-token>
# PYLON_OPEN_ACCESS_TOKEN=<read-token>

# KOTH margin / tail / champion-share / dethrone-z are frozen in code, not env.
# The confirmation-seed count is operator-set but must match network-wide.
VALIDATOR_KOTH_CONFIRMATION_SEEDS=3

# Optional validator settings (defaults shown).
# VALIDATOR_RUN_SIZE=full
# VALIDATOR_SWEEP_SECONDS=120
# VALIDATOR_EPOCH_SECONDS=3600
# VALIDATOR_QUEUE_LIMIT=50
# VALIDATOR_DITTOBENCH_POLL_SECONDS=10
# VALIDATOR_DITTOBENCH_TIMEOUT_SECONDS=2400
# VALIDATOR_HTTP_TIMEOUT_SECONDS=30
# VALIDATOR_MIN_STAKE_TAO=0
# VALIDATOR_REQUIRE_COMMIT_REVEAL=true
# VALIDATOR_WEIGHT_VERSION_KEY=<package-spec-version>
# VALIDATOR_LOG_LEVEL=INFO
# VALIDATOR_DITTOBENCH_MOCK=true
# WANDB_MODE=disabled
# WANDB_PROJECT=ditto-sn118
# WANDB_ENTITY=<entity>
# WANDB_RUN_NAME=<run-name>

# --- Screener worker ---

SCREENER_PLATFORM_API_URL=https://<platform-host>
SCREENER_HOTKEY=<screener-ss58-address>

# Prefer wallet files. SCREENER_MNEMONIC is the container-friendly fallback.
SCREENER_WALLET_NAME=<coldkey-name>
SCREENER_WALLET_HOTKEY=<hotkey-name>
# SCREENER_MNEMONIC=<12-or-24-word-mnemonic>

# Optional screener settings (defaults shown).
# SCREENER_DOCKER_BIN=docker
# SCREENER_BUILD_TIMEOUT_SECONDS=1200
# SCREENER_RUN_TIMEOUT_SECONDS=120
# SCREENER_BUILD_MEMORY=2g
# SCREENER_GH_TOKEN_FILE=/run/secrets/gh-token
# SCREENER_PIDS_LIMIT=512
# SCREENER_HEALTH_PATH=/health
# SCREENER_CONTAINER_PORT=8080
# SCREENER_SMOKE_ENV=OPENROUTER_API_KEY=sk-screener-smoke
# SCREENER_MAX_TARBALL_BYTES=20971520
# SCREENER_POLL_SECONDS=30
# SCREENER_QUEUE_LIMIT=20
# SCREENER_HTTP_TIMEOUT_SECONDS=60
# SCREENER_LOG_LEVEL=INFO
