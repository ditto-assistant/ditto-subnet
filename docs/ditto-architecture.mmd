%% SN118 (DittoBench) system architecture. Everything shown is shipped.
%% Colour = trust boundary: public repo, private coordinator, external service.

flowchart TB

  %% ===================== MINER (offchain) =====================
  subgraph MINER["Miner (offchain)"]
    direction TB
    m_harness["ditto-harness / dittobench-starter-kit<br/>writes a memory harness<br/>(MCP tools + agent loop)"]
    m_cli["ditto-subnet · miner_cli<br/>ditto upload | status | verify<br/>tar + sign + submit"]
  end

  %% ===================== PLATFORM (private coordinator) =====================
  subgraph PLATFORM["ditto-platform · coordinator (private)"]
    direction TB
    p_intake["Miner intake<br/>/upload/check · /upload/agent<br/>payment verify · object store"]
    p_screen["Screener build-gate<br/>docker build + serve /health smoke"]
    p_tickets["Ticket lease<br/>issue_ticket · SCORING_QUORUM=3<br/>30-min TTL · one (agent,validator) row"]
    p_final["Finalize at quorum<br/>median of 3 signed scores<br/>ATH + duplicate check · audit log"]
    p_public["Public API<br/>/leaderboard · /agent/{id}/scores (k=3 + median)<br/>/agent/{id}/dataset · /audit"]
    p_ledger[("Ledger DB<br/>agents · scores · banned_hotkeys")]
  end

  %% ===================== VALIDATOR HOST (k=3 independent) =====================
  subgraph VALHOST["Validator host · one per hotkey, k=3 independent"]
    direction TB
    v_worker["ditto-subnet · validator worker<br/>work_loop (sweep) · weight_loop"]
    v_fold["Weight fold · weights.py<br/>KOTH champion 0.9 · dethrone margin 0.05<br/>+ z-band (dethrone_z 1.64) · tail 4"]

    subgraph DBAPI["dittobench-api · scoring engine (co-located, :8080)"]
      direction TB
      d_sandbox["sandbox / runner<br/>docker build + run the miner harness"]
      d_scorer["scorer<br/>composite = 0.5·tool + 0.5·memory<br/>× tool-eff / canary / metamorphic gates<br/>+ composite_stderr"]
      d_grade["deterministic grader<br/>judge-free, per answer_kind"]
      d_astfp["astfp<br/>lexical + AST anti-copy fingerprint"]
      d_egress["egress-proxy<br/>fail-closed hostname allowlist"]
    end

    subgraph GW["Locked model gateway (Qwen3-32B)"]
      direction TB
      g_relay["model-relay<br/>Qwen/Qwen3-32B-TEE (Chutes)"]
      g_local["or local Ollama / vLLM<br/>qwen3:32b"]
    end

    v_pylon["Pylon sidecar (:8001)<br/>signs set_weights<br/>u16 · version_key · commit-reveal"]
  end

  %% ===================== PUBLIC BUILD DEPS =====================
  subgraph PUB["Public build dependencies"]
    direction TB
    r_datagen["dittobench-datagen<br/>dataset generator + judge-free grader<br/>(regenerated from the seed)"]
    r_harness["ditto-harness<br/>reference memory library"]
  end

  %% ===================== OBSERVABILITY =====================
  subgraph OBS["Observability"]
    direction TB
    o_wandb["W&B run logging"]
    o_dash["Public dashboard<br/>current champion + stats"]
  end

  %% ===================== EXTERNAL =====================
  x_store[("Object store<br/>presigned tarballs")]
  x_llm(("Chutes TEE<br/>(or local GPU)"))
  x_chain(("Subtensor · finney<br/>netuid 118"))

  %% ---- miner flow ----
  m_harness --> m_cli
  m_cli ==>|"1 upload (signed)"| p_intake
  p_intake --> x_store
  p_intake --> p_ledger
  p_intake -.->|"2 queued"| p_screen
  p_screen -->|"3 build+serve pass"| p_ledger

  %% ---- validator scoring flow ----
  v_worker ==>|"4 request job"| p_tickets
  p_tickets -->|"ticket + seed"| v_worker
  v_worker -->|"5 download"| x_store
  v_worker -->|"6 score"| d_sandbox
  d_sandbox --> d_scorer
  d_scorer --> d_grade
  d_scorer --> d_astfp
  d_sandbox -->|"runs harness"| d_egress
  d_egress --> g_relay
  d_egress --> g_local
  g_relay --> x_llm
  d_grade -->|"seed to dataset"| r_datagen
  d_sandbox -.->|"build pulls"| r_harness
  d_scorer ==>|"7 signed ScoreReport"| v_worker
  v_worker ==>|"8 submit signed score"| p_final
  p_final --> p_ledger
  p_final --> p_public

  %% ---- weights flow ----
  p_public -->|"9 median ledger"| v_fold
  v_worker --> v_fold
  v_fold ==>|"10 set_weights"| v_pylon
  v_pylon ==> x_chain

  %% ---- observability ----
  p_public --> o_dash
  v_worker -.-> o_wandb

  %% ---- styles ----
  classDef pub fill:#e6ffed,stroke:#2da44e,color:#0a3d1f;
  classDef priv fill:#fff4e6,stroke:#d98324,color:#7a4a00;
  classDef ext fill:#eef,stroke:#557,color:#225;
  classDef host fill:#f5f0ff,stroke:#7a5cc0,color:#3a2a6a;

  class m_harness,m_cli,v_worker,v_fold,d_sandbox,d_scorer,d_grade,d_astfp,d_egress,g_relay,r_datagen,r_harness pub;
  class p_intake,p_screen,p_tickets,p_final,p_public,p_ledger priv;
  class g_local,v_pylon,o_wandb,o_dash host;
  class x_store,x_llm,x_chain ext;
