
flowchart TB

  %% ================= REPO 1: ditto-subnet (miner + validator) =================
  subgraph SUBNET["REPO ditto-subnet · miner + validator + evaluator"]
    direction TB

    subgraph MINER["ditto.miner_cli  (BUILT on feat/miner-cli — merge pending)"]
      mc_cli["cli/__main__ + commands<br/>upload · status · verify  [ETHAN]"]
      mc_blocks["wallet · signing · payment · tar_validator<br/>api_client · network · factory  (built)"]
      mc_defer["deferred tar checks: manifest · import-allowlist<br/>· schema-diff  (stubs — need harness iface) [ETHAN]"]
    end

    subgraph VALIDATOR["ditto.validator  (NOT BUILT)"]
      v_loops["work_loop · heartbeat_loop · weight_loop  [DAN]"]
      v_eval["ditto.evaluator<br/>sandbox · build · runtime  [NICK]"]
      v_datagen["data_source / synthetic-data gen  [NICK+OMAR]"]
      v_bench["ditto bench · eval_runner · failure_classifier  [NICK+OMAR]"]
      v_proxy["ditto.proxy egress sidecar<br/>OpenRouter allowlist + cost cap  [NICK]"]
    end
  end

  %% ================= REPO 2: ditto-platform (API) =================
  subgraph PLATFORM["REPO ditto-platform · ditto.api_server (split out by [DAN])"]
    direction TB

    subgraph INTAKE["miner intake (BUILT)"]
      ep_up["/upload/eval-pricing · /check · /agent<br/>/retrieval/agent · /status  (built)"]
      svc_built["payment_verifier · pricing · storage  (built)"]
    end

    subgraph SCREEN["pre-screen + smoke test  (NOT BUILT) [DAN]"]
      sc_screen["screening loop: uploaded -> screening_passed/failed<br/>smoke test miner harness in sandbox"]
    end

    subgraph VALEP["validator-facing endpoints  (NOT BUILT) [DAN]"]
      vep_reg["/validator/register (+ sig auth)"]
      vep_work["/validator/request-evaluation (poll)"]
      vep_dl["/validator/agent/{id}/download"]
      vep_hb["/validator/heartbeat"]
      vep_score["/validator/submit-score"]
      vep_w["/scoring/weights"]
      vep_admin["/admin/* (ban · force re-eval)"]
    end

    subgraph SCORING["ditto.scoring  (NOT BUILT) [DAN]"]
      sc_eng["Pareto-GM · ATH gate (1%) · PureWTA weight_builder"]
    end
  end

  %% ================= REPO 3: shared + harness =================
  subgraph SHARED["shared libs (chain · db · api_models)"]
    sh_chain["ditto.chain (Pylon client, put_weights)  (built)"]
    sh_db["ditto.db: agents · evaluation_payments  (built)<br/>+ scores · validators · banned_hotkeys  [DAN]"]
    sh_models["ditto.api_models wire shapes  (built)"]
  end

  subgraph HARNESS["REPO ditto-harness · Rust memory harness (BUILT, not yet wired)"]
    h_ref["reference harness (forkable by miners)"]
  end

  %% ================= DASHBOARD (NEW) =================
  subgraph DASH["observability / public UI  (NOT BUILT)"]
    d_wandb["W&B run logging (scores, eval runs)  [TBD]"]
    d_ui["public dashboard: current winner + key stats  [TBD]"]
  end

  %% ================= EXTERNAL =================
  x_chain(("local subtensor<br/>(hosted)"))
  x_s3(("S3 / minio"))
  x_or(("OpenRouter"))

  %% ---- flows ----
  mc_cli --> mc_blocks
  mc_blocks ==>|HTTP upload| ep_up
  ep_up --> svc_built --> x_s3
  ep_up --> sh_db
  ep_up --> sh_chain --> x_chain

  ep_up -.agent uploaded.-> sc_screen
  sc_screen -.passed.-> vep_work

  v_loops -.poll.-> vep_work
  vep_work --> sh_db
  v_loops --> vep_dl --> x_s3
  v_loops --> v_eval --> v_datagen --> v_bench
  v_eval --> v_proxy --> x_or
  v_eval -.runs.-> h_ref
  v_loops --> vep_hb
  v_bench --> vep_score --> sh_db
  vep_score -.triggers.-> sc_eng
  sc_eng --> vep_w
  v_loops -.fetch weights.-> vep_w
  v_loops ==>|put_weights| sh_chain

  sc_eng -.runs/scores.-> d_wandb --> d_ui
  sh_db -.winner.-> d_ui

